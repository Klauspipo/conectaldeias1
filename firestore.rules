rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'emersonsouza609e@gmail.com' ||
        request.auth.uid == 'EMERSON_UID_PLACEHOLDER' // Replace if known
      );
    }

    function isBlocked(userId) {
       let userDoc = get(/databases/$(database)/documents/users/$(userId));
       return isSignedIn() && userId != request.auth.uid && 'blockedUsers' in userDoc.data && request.auth.uid in userDoc.data.blockedUsers;
    }

    function isFollowing(userId) {
       return exists(/databases/$(database)/documents/follows/$(request.auth.uid + "_" + userId));
    }

    // --- Reports ---
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Marketplace ---
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    // --- VIP Items ---
    match /vip_items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Stories ---
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // --- Posts ---
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    function isValidPost(data) {
      return data.authorId == request.auth.uid
        && data.imageUrl is string && data.imageUrl.size() <= 1000;
    }

    // --- Follows ---
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid && !isBlocked(request.resource.data.followingId);
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    // --- Chats ---
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastSenderId', 'updatedAt']);
    }

    // --- Messages ---
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        && request.resource.data.senderId == request.auth.uid;
    }

    // --- Village Events ---
    match /village_events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // --- Village Messages ---
    match /village_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
    }
  }
}
